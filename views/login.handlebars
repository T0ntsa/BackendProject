<main class="auth-shell">
  <section class="auth-panel">
    <div class="brand-mark">Pet Training</div>
    <h1>Welcome back</h1>
    <p class="text-muted mb-4">Sign in to manage training tasks, trainers, and dog profiles.</p>

    <div id="auth-message" class="alert d-none" role="alert"></div>

    <form id="login-form" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input id="email" name="email" type="email" class="form-control" placeholder="admin@abc.com" required>
        <div class="invalid-feedback">Please enter a valid email address.</div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label">Password</label>
        <input id="password" name="password" type="password" class="form-control" minlength="6" required>
        <div class="invalid-feedback">Password must be at least 6 characters.</div>
      </div>

      <button type="submit" class="btn btn-success w-100">Sign in</button>
    </form>

    <p class="auth-switch">No account yet? <a href="/register">Create one</a></p>
  </section>
</main>

<script src="/auth.js"></script>
